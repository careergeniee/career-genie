}, {"id": "docs_superpowers_plans_2026_07_15_cloudflare_pages_functions_port_jose_library", "label": "jose (JWT verification library)", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-07-15-cloudflare-pages-functions-port.md", "source_location": "lines 7, 9, 16, 134-140", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "jose is fully ESM and Workers-native, avoiding the CommonJS/ESM crash previously hit on Vercel; used to verify Firebase ID tokens by hand instead of firebase-admin."}, {"id": "docs_superpowers_plans_2026_07_15_cloudflare_pages_functions_port_firebase_admin_rejected", "label": "Decision to avoid firebase-admin in functions/", "file_type": "rationale", "source_file": "docs/superpowers/plans/2026-07-15-cloudflare-pages-functions-port.md", "source_location": "lines 7, 16", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "firebase-admin is not reliably supported on the Cloudflare Workers runtime, so Firebase ID token verification is reimplemented manually with jose against Google's public JWKS instead."}, {"id": "docs_superpowers_plans_2026_07_15_cloudflare_pages_functions_port_google_jwks_endpoint", "label": "Google public JWKS endpoint (securetoken@system.gserviceaccount.com)", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-07-15-cloudflare-pages-functions-port.md", "source_location": "lines 16, 207", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_plans_2026_07_15_cloudflare_pages_functions_port_vitest_config", "label": "vitest.config.ts (broadened test.include)", "file_type": "code", "source_file": "docs/superpowers/plans/2026-07-15-cloudflare-pages-functions-port.md", "source_location": "lines 32, 45, 50-71", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_plans_2026_07_15_cloudflare_pages_functions_port_src_lib_ai_